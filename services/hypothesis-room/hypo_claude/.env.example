# Required — OpenAI API
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_CREATIVE_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# Optional — Anthropic (future)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional — External APIs
# SEMANTIC_SCHOLAR_API_KEY=
# TAVILY_API_KEY=

# Server
HYPO_CLAUDE_HOST=0.0.0.0
HYPO_CLAUDE_PORT=8001

# LLM runtime
LLM_REQUEST_TIMEOUT_S=60
LLM_MAX_RETRIES=2
LLM_PROVIDER=openai

# Pipeline defaults
PIPELINE_MAX_HYPOTHESES_PER_STRATEGY=5
PIPELINE_TRIBUNAL_CYCLES=3
PIPELINE_DEDUP_THRESHOLD=0.80
