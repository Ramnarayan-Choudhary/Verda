# ═══════════════════════════════════════════════════════════════
# VREDA Hypothesis Room — Environment Variables
# ═══════════════════════════════════════════════════════════════
# See LLM_PROVIDERS.md for the tiered model routing strategy.
#
# MINIMUM REQUIRED: Set CHATANYWHERE_API_KEY to cover all tiers.
# Or set K2THINK_API_KEY as a universal fallback.
# ═══════════════════════════════════════════════════════════════

# ─── LLM Provider: ChatAnywhere (PRIMARY — covers all tiers) ───
# One API key provides 3 models optimized for each tier:
#   REASONING → deepseek-r1-0528 (critic, meta-reviewer, judge)
#   CREATIVE  → deepseek-v3 (proposer, evolver, seed generation)
#   FAST      → gpt-4o-mini-ca (extraction, verifiability, filtering)
CHATANYWHERE_API_KEY=your-chatanywhere-api-key
CHATANYWHERE_BASE_URL=https://api.chatanywhere.tech/v1
CHATANYWHERE_REASONING_MODEL=deepseek-r1-0528
CHATANYWHERE_CREATIVE_MODEL=deepseek-v3
CHATANYWHERE_FAST_MODEL=gpt-4o-mini-ca

# ─── LLM Provider: K2Think (Universal Fallback) ───
# Used by: ALL agents when no better provider is available
# K2THINK_API_KEY=your-k2think-api-key
# K2THINK_BASE_URL=https://api.k2think.ai/v1
# K2THINK_MODEL=MBZUAI-IFM/K2-Think-v2

# ─── LLM Provider: OpenRouter → Gemini Flash (FAST Tier — optional) ───
# Used by: Paper extraction, verifiability scoring, filtering
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ─── LLM Provider: DeepSeek R1 Direct (REASONING — optional) ───
# Used by: Critic, Meta-Reviewer, Tournament Judge (if you have a direct key)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-reasoner

# ─── LLM Provider: OpenAI GPT-4o Direct (CREATIVE — optional) ───
# Used by: Proposer, Evolver (fallback)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# OpenAI Responses API web search (used in Stage 2 grounding)
# OPENAI_WEBSEARCH_MODEL=gpt-4o
# OPENAI_WEBSEARCH_TIMEOUT_S=35
# OPENAI_WEBSEARCH_MAX_RESULTS=5
# OPENAI_WEBSEARCH_CONTEXT_SIZE=medium

# ─── LLM Provider: Anthropic Claude (REASONING — optional) ───
# Routed through OpenRouter for OpenAI-compatible API
# ANTHROPIC_API_KEY=your-openrouter-api-key-for-claude
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5-20250929

# ─── Supabase (same instance as Next.js app) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Required for pgvector via vecs library (Postgres connection string):
SUPABASE_POSTGRES_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── External APIs (optional — increases rate limits) ───
GITHUB_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=your-tavily-api-key

# ─── Server ───
HOST=0.0.0.0
PORT=8000

# ─── LLM Runtime Safety ───
LLM_REQUEST_TIMEOUT_S=45
LLM_MAX_RETRIES=1
# Force all roles to use OpenAI (gpt-4o) only.
LLM_FORCE_OPENAI_ONLY=true

# ─── Pipeline Defaults ───
DEFAULT_MAX_SEEDS=200
DEFAULT_MAX_CYCLES=4
DEFAULT_TOP_K=10
