# ═══════════════════════════════════════════════════════════════
# VREDA.ai — Web App Environment Variables (apps/web/.env.local)
# ═══════════════════════════════════════════════════════════════
# Copy this file to apps/web/.env.local and fill in your keys.
# For Python hypothesis service config, see:
#   services/hypothesis-room/.env.example
# ═══════════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PAPER_BUCKET=Research-Paper

# AI APIs — OpenAI (recommended for best reasoning + embeddings)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o                            # Or gpt-4o-mini for cheaper
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# AI APIs — Fallback providers (used when OpenAI is not configured)
GEMINI_API_KEY=your-gemini-api-key             # Required for embeddings fallback
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
DEEPSEEK_API_KEY=your-deepseek-api-key         # Optional
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com
K2THINK_API_KEY=your-k2think-api-key           # Optional — LLM fallback

# GitHub (optional — increases API rate limit from 60/hr to 5000/hr)
GITHUB_TOKEN=your-github-personal-access-token

# Hypothesis Service (Python — must be running for hypothesis generation)
HYPOTHESIS_SERVICE_URL=http://127.0.0.1:8000
HYPOTHESIS_GPT_SERVICE_URL=http://127.0.0.1:8100
HYPOTHESIS_CLAUDE_SERVICE_URL=http://127.0.0.1:8001
HYPOTHESIS_SERVICE_AUTOSTART=1                  # Dev-only helper: auto-start local Python service if down
HYPOTHESIS_GROUNDING_TIMEOUT_SECONDS=240        # Per-request grounding stage timeout passed to Python service
# HYPOTHESIS_SERVICE_DIR=services/hypothesis-room
# HYPOTHESIS_SERVICE_PYTHON=python3

# App (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAT_WARROOM_UI=0
