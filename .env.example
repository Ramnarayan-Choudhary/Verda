# ============================================================================
# VREDA Monorepo - Canonical Environment Template
# ============================================================================
# Single source of truth for all apps/services in this repo.
# Copy to .env.local in repo root and fill real values.
#   cp .env.example .env.local
# ============================================================================

# ----------------------------------------------------------------------------
# Shared / Web App (apps/web)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PAPER_BUCKET=Research-Paper

GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com
K2THINK_API_KEY=your-k2think-api-key
K2THINK_BASE_URL=https://api.k2think.ai/v1
K2THINK_MODEL=MBZUAI-IFM/K2-Think-v2

OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_CREATIVE_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

GITHUB_TOKEN=
SEMANTIC_SCHOLAR_API_KEY=
TAVILY_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAT_WARROOM_UI=1
NEXT_PUBLIC_IRIS_ENABLED=1

# ----------------------------------------------------------------------------
# Web -> IRIS Ideation service (services/hypothesis-room/iris)
# ----------------------------------------------------------------------------
IRIS_SERVICE_URL=http://127.0.0.1:5001

# ----------------------------------------------------------------------------
# Web -> Hypothesis service routing
# ----------------------------------------------------------------------------
HYPOTHESIS_SERVICE_URL=http://127.0.0.1:8000
HYPOTHESIS_GPT_SERVICE_URL=http://127.0.0.1:8100
HYPOTHESIS_CLAUDE_SERVICE_URL=http://127.0.0.1:8001
HYPOTHESIS_SERVICE_AUTOSTART=1
HYPOTHESIS_GROUNDING_TIMEOUT_SECONDS=240
HYPOTHESIS_SERVICE_DIR=services/hypothesis-room
HYPOTHESIS_SERVICE_PYTHON=python3

# ----------------------------------------------------------------------------
# services/hypothesis-room (vreda_hypothesis)
# ----------------------------------------------------------------------------
CHATANYWHERE_API_KEY=your-chatanywhere-api-key
CHATANYWHERE_BASE_URL=https://api.chatanywhere.tech/v1
CHATANYWHERE_REASONING_MODEL=deepseek-r1-0528
CHATANYWHERE_CREATIVE_MODEL=deepseek-v3
CHATANYWHERE_FAST_MODEL=gpt-4o-mini-ca

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5-20250929

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_POSTGRES_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

HOST=0.0.0.0
PORT=8000
LLM_REQUEST_TIMEOUT_S=45
LLM_MAX_RETRIES=1
LLM_FORCE_OPENAI_ONLY=true
LLM_PROVIDER=openai

DEFAULT_MAX_SEEDS=200
DEFAULT_MAX_CYCLES=4
DEFAULT_TOP_K=10

# ----------------------------------------------------------------------------
# hypo-claude service
# ----------------------------------------------------------------------------
HYPO_CLAUDE_HOST=0.0.0.0
HYPO_CLAUDE_PORT=8001
PIPELINE_MAX_HYPOTHESES_PER_STRATEGY=5
PIPELINE_TRIBUNAL_CYCLES=3
PIPELINE_DEDUP_THRESHOLD=0.80
PIPELINE_MAX_CONCURRENT_STRATEGIES=4
PIPELINE_MAX_CONCURRENT_CRITICS=4

# ----------------------------------------------------------------------------
# hypo-gpt service
# ----------------------------------------------------------------------------
OPENAI_WEBSEARCH_MODEL=gpt-4o
OPENAI_WEBSEARCH_TIMEOUT_S=35
OPENAI_WEBSEARCH_MAX_RESULTS=4
OPENAI_WEBSEARCH_CONTEXT_SIZE=medium

HYPOTHESIS_GPT_HOST=0.0.0.0
HYPOTHESIS_GPT_PORT=8100
HYPOTHESIS_GPT_REQUEST_TIMEOUT_S=45
HYPOTHESIS_GPT_MAX_RETRIES=1
HYPOTHESIS_GPT_ENABLE_EXTERNAL_GROUNDING=true
HYPOTHESIS_GPT_EXTERNAL_GROUNDING_TIMEOUT_S=20
HYPOTHESIS_GPT_EXTERNAL_GROUNDING_MAX_DOCS=8
